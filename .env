# PVTsim Nova bridge — update this to the IP shown by `ipconfig` on the Windows VM
# (Look for the Parallels/Ethernet adapter IPv4 address, e.g. 10.211.55.x)
PVTSIM_BRIDGE_URL=http://10.211.55.3:9000

# KBC Multiflash bridge — same Windows VM IP, different port
MULTIFLASH_BRIDGE_URL=http://10.211.55.3:9001
